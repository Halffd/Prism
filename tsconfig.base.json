{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@prism/source"],
    "baseUrl": ".",
    "paths": {
      "@prism/redux-store": ["libs/redux-store/src/index.ts"],
      "@prism/api-client": ["libs/api-client/src/index.ts"],
      "@prism/shared-db": ["libs/shared-db/src/index.ts"],
      "@prism/shared-types": ["libs/shared-types/src/index.ts"],
      "@prism/image-gen": ["libs/image-gen/src/index.ts"],
      "@prism/llm-service": ["libs/llm-service/src/index.ts"],
      "@prism/firebase-auth": ["libs/firebase-auth/src/index.ts"]
    }
  }
}
