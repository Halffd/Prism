# Prism Self-Hosting Environment Configuration

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL= # Your Supabase project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY= # Your Supabase anon key
SUPABASE_SERVICE_ROLE_KEY= # Your Supabase service role key

# API Configuration
PRISM_API_URL=http://localhost:3000
PRISM_API_KEY= # Optional API key for additional security

# Database Configuration
DATABASE_URL= # PostgreSQL connection string for Supabase

# Authentication Configuration
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# LLM Provider Configuration
OPENAI_API_KEY= # Your OpenAI API key (optional if using local models)
LLM_PROVIDER=openai # Options: openai, anthropic, google, ollama, etc.
LLM_MODEL=gpt-3.5-turbo # Default model to use

# Image Generation (if using Hugging Face)
HF_API_KEY= # Your Hugging Face API key for image generation

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com

# Storage Configuration (for file uploads)
STORAGE_PROVIDER=supabase # Options: supabase, s3, local
STORAGE_BUCKET=prism-chat-history

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes

# Logging
LOG_LEVEL=info
ENABLE_TELEMETRY=false