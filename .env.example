# Prism Self-Hosting Environment Configuration

# ==============================
# General Configuration
# ==============================
DOMAIN=localhost
SITE_URL=http://localhost:3000
ACME_EMAIL=your-email@example.com

# ==============================
# Supabase Configuration
# ==============================
NEXT_PUBLIC_SUPABASE_URL=         # Your Supabase project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=    # Your Supabase anon key
SUPABASE_SERVICE_ROLE_KEY=        # Your Supabase service role key
POSTGRES_PASSWORD=postgres         # PostgreSQL password

# ==============================
# API Configuration
# ==============================
PRISM_API_URL=http://localhost:3000
PRISM_API_KEY=                     # Optional API key for additional security
DATABASE_URL=                      # PostgreSQL connection string

# ==============================
# Authentication Configuration
# ==============================
JWT_SECRET=                        # JWT signing secret (min 32 chars)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ==============================
# LLM Provider Configuration
# ==============================
LLM_PROVIDER=openai               # Default provider
LLM_MODEL=gpt-3.5-turbo           # Default model

# Cloud Providers
OPENAI_API_KEY=                    # OpenAI API key
ANTHROPIC_API_KEY=                 # Anthropic (Claude) API key
GOOGLE_API_KEY=                    # Google Gemini API key
DEEPSEEK_API_KEY=                  # DeepSeek API key
GROK_API_KEY=                      # Grok (xAI) API key
OPENROUTER_API_KEY=                # OpenRouter API key
POE_API_KEY=                       # Poe API key

# New Cloud Providers
NVIDIA_NIM_API_KEY=                # NVIDIA NIM API key
GROQ_API_KEY=                      # Groq API key
CEREBRAS_API_KEY=                  # Cerebras API key
CLOUDFLARE_WORKERS_API_KEY=        # Cloudflare Workers AI API key
FIREWORKS_API_KEY=                 # Fireworks AI API key
ZAI_API_KEY=                       # Z.AI API key

# Local / Self-Hosted Providers
OLLAMA_API_URL=http://localhost:11434   # Ollama server URL
KOBOLDCPP_API_URL=http://localhost:5001 # KoboldCpp server URL
LLAMACPP_API_URL=http://localhost:8080  # llama.cpp server URL
SGLANG_API_URL=http://localhost:30000   # SGLang server URL

# ==============================
# Image Generation
# ==============================
HF_API_KEY=                        # Hugging Face API key

# ==============================
# CORS Configuration
# ==============================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,https://yourdomain.com

# ==============================
# Storage Configuration
# ==============================
STORAGE_PROVIDER=supabase          # Options: supabase, s3, local
STORAGE_BUCKET=prism-chat-history

# ==============================
# Rate Limiting
# ==============================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000        # 15 minutes

# ==============================
# Logging
# ==============================
LOG_LEVEL=info
ENABLE_TELEMETRY=false
